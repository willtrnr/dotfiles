{
  "$schema": "https://app.kilo.ai/config.json",
  "model": "empero-ai/Qwythos-9B-Claude-Mythos-5-1M",
  "provider": {
    "local": {
      "name": "Local",
      "options": {
        "baseURL": "http://localhost:12434/v1",
        "apiKey": "none"
      },
      "models": {
        "empero-ai/Qwythos-9B-Claude-Mythos-5-1M": {
          "name": "Qwythos-9B-Claude-Mythos-5-1M",
          "tool_call": true,
          "reasoning": true,
          "temperature": true,
          "modalities": {
            "input": [
              "text"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 262144,
            "output": 16384
          }
        },
        "Jackrong/Qwopus3.5-9B-Coder": {
          "name": "Qwopus3.5 9B Coder",
          "tool_call": true,
          "reasoning": true,
          "temperature": true,
          "modalities": {
            "input": [
              "text"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 131072,
            "output": 16384
          }
        }
      }
    }
  },
  "enabled_providers": [
    "local"
  ],
  "lsp": true,
  "permission": {
    "*": "ask",
    "bash": {
      "*": "ask",
      "cargo search *": "allow",
      "cat *": "allow",
      "cp *": "ask",
      "cut *": "allow",
      "date": "allow",
      "df *": "allow",
      "du *": "allow",
      "find *": "allow",
      "free *": "allow",
      "ghidra_*": "deny",
      "git diff *": "allow",
      "git log *": "allow",
      "git status *": "allow",
      "grep *": "allow",
      "head *": "allow",
      "jq *": "allow",
      "ls *": "allow",
      "mv *": "ask",
      "npm search *": "allow",
      "rm *": "ask",
      "sort *": "allow",
      "tail *": "allow",
      "tr *": "allow",
      "uniq *": "allow",
      "which *": "allow",
      "whoami": "allow",
      "windbg_*": "deny"
    },
    "doom_loop": "deny",
    "edit": "ask",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "lsp": "allow",
    "read": "allow",
    "task": "allow",
    "todowrite": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "context7_*": "allow",
    "deepwiki_*": "allow",
    "filesystem_*": "ask",
    "filesystem_get_*": "allow",
    "filesystem_list_*": "allow",
    "filesystem_read_*": "allow",
    "filesystem_search_files": "allow",
    "filesystem_directory_tree": "allow",
    "ghidra_*": "allow",
    "ghidra_delete_*": "ask",
    "ghidra_exit_ghidra": "deny",
    "ghidra_save_*": "ask",
    "ghidra_update_*": "ask",
    "microsoft-learn_*": "allow",
    "rva_*": "allow",
    "windbg_*": "allow"
  },
  "indexing": {
    "enabled": true,
    "provider": "openai-compatible",
    "model": "nomic-ai/nomic-embed-text-v1.5",
    "openai-compatible": {
      "baseUrl": "http://localhost:12434/v1",
      "apiKey": "none"
    },
    "vectorStore": "lancedb",
    "dimension": 768
  },
  "mcp": {
    "filesystem": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-filesystem@latest"
      ],
      "enabled": true
    },
    "microsoft-learn": {
      "type": "remote",
      "url": "https://learn.microsoft.com/api/mcp",
      "enabled": false
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": false
    },
    "deepwiki": {
      "type": "remote",
      "url": "https://mcp.deepwiki.com/mcp",
      "enabled": false
    },
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp",
      "oauth": true,
      "enabled": false
    },
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp",
      "enabled": false
    }
  }
}
