{
  "$schema": "https://app.kilo.ai/config.json",
  "model": "local/Jackrong/Qwopus3.5-9B-Coder-MTP",
  "provider": {
    "local": {
      "name": "Local",
      "options": {
        "baseURL": "http://localhost:11434/v1",
        "apiKey": "none"
      },
      "models": {
        "Jackrong/Qwopus3.5-9B-Coder-MTP": {
          "name": "Qwopus3.5 9B Coder MTP",
          "tool_call": true,
          "reasoning": true,
          "limit": {
            "context": 131072,
            "output": 20480
          }
        },
        "Jackrong/Qwopus3.5-9B-Coder": {
          "name": "Qwopus3.5 9B Coder",
          "tool_call": true,
          "reasoning": true,
          "limit": {
            "context": 131072,
            "output": 20480
          }
        }
      }
    }
  },
  "enabled_providers": [
    "local"
  ],
  "lsp": true,
  "permission": {
    "*": "ask",
    "bash": {
      "*": "ask",
      "cargo search *": "allow",
      "cat *": "allow",
      "cp *": "ask",
      "cut *": "allow",
      "date": "allow",
      "df *": "allow",
      "du *": "allow",
      "find *": "allow",
      "free *": "allow",
      "git diff *": "allow",
      "git log *": "allow",
      "git status *": "allow",
      "grep *": "allow",
      "head *": "allow",
      "jq *": "allow",
      "ls *": "allow",
      "mv *": "ask",
      "npm search *": "allow",
      "rm *": "ask",
      "sort *": "allow",
      "tail *": "allow",
      "tr *": "allow",
      "uniq *": "allow",
      "whoami": "allow"
    },
    "doom_loop": "deny",
    "edit": "ask",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "lsp": "allow",
    "read": "allow",
    "task": "allow",
    "todowrite": "allow",
    "webfetch": "allow",
    "websearch": "allow"
  },
  "indexing": {
    "enabled": false,
    "provider": "openai-compatible",
    "model": "nomic-ai/nomic-embed-text-v1.5",
    "openai-compatible": {
      "baseUrl": "http://localhost:11434/v1",
      "apiKey": "none"
    },
    "vectorStore": "lancedb",
    "dimension": 768
  },
  "mcp": {
    "kubernetes": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "kubernetes-mcp-server@latest"
      ],
      "enabled": false,
      "timeout": 15000
    }
  }
}
